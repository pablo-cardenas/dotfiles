#!/usr/bin/env perl
use strict;
use warnings;
use Text::BibTeX;

my ($src) = @ARGV;
my $bib = $ENV{BIB} or die "BIB is not set\n";
-f $bib or die "No BIB=$bib\n";

my $bibfile = Text::BibTeX::File->new($bib);

my %entry;
while (my $e = Text::BibTeX::Entry->new($bibfile)) {
    next unless $e->parse_ok;
    next unless $e->metatype eq BTE_REGULAR;

    my $key = $e->key;

    $entry{$key} = {
        author    => $e->get("author")    // "",
        title     => $e->get("title")     // "",
        year      => $e->get("year")      // "",
        localrefs => $e->get("localrefs") // "",
    };
}

die "key not found: $src\n" unless exists $entry{$src};

my %localrefs = $entry{$src}{localrefs} =~ /\s*([^=]+)=(\S+)\s*/g;
my @sorted = (!grep { $_ !~ /^\d+$/ } keys %localrefs)
    ? sort { $a <=> $b } keys %localrefs
    : sort { $a cmp $b } keys %localrefs;

for my $n (@sorted) {
    my $dst = $localrefs{$n};

    my $author = $entry{$dst}{author} // "?";
    my $year   = $entry{$dst}{year}   // "?";
    my $title  = $entry{$dst}{title}  // "?";

    print "$dst | $n | $title | $author | $year\n";
}
